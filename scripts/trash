#!/bin/bash
# Move files to trash instead of permanent deletion
TRASH_DIR="$HOME/.trash"
mkdir -p "$TRASH_DIR"

if [ $# -eq 0 ]; then
    echo "Usage: trash <file1> [file2] ..."
    echo "Moves files to ~/.trash instead of permanent deletion"
    exit 1
fi

for file in "$@"; do
    if [ -e "$file" ]; then
        filename=$(basename "$file")
        timestamp=$(date +%Y%m%d_%H%M%S)
        target="${TRASH_DIR}/${timestamp}_${filename}"
        mv "$file" "$target"
        echo "✅ Moved to trash: $target"
    else
        echo "⚠️  File not found: $file"
    fi
done
